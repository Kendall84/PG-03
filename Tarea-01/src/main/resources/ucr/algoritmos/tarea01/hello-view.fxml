<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17" fx:controller="ucr.algoritmos.tarea01.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Generador de Progresiones" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="10.0" alignment="CENTER">
        <Label text="Tipo:"/>
        <ComboBox fx:id="progressionComboBox" prefWidth="150.0"/>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <Label text="Cantidad:"/>
        <TextField fx:id="countTextField" prefWidth="60.0" text="10"/>
    </HBox>

    <Button text="Generar" onAction="#onGenerateButtonClick"/>

    <TextArea fx:id="resultTextArea" editable="false" prefHeight="200.0" wrapText="true"/>
</VBox>
